import("sheep-farm/hayahoo", as=yahoo)

let price = yahoo::price("AAPL")
let change = yahoo::change("AAPL")
let quote = yahoo::quote("AAPL")
let hist = yahoo::history("AAPL", {"range": "3mo", "interval": "1d"})
let search = yahoo::search("petrobras", {"limit": 5})
let table = yahoo::quotes(["AAPL", "MSFT", "PETR4.SA", "BTC-USD"])

